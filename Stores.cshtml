@page
@model gymmm.Pages.StoresModel
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Stores</title>
    <link rel="stylesheet" href="style.css" />
</head>
<body>
    <nav class="navbar">
        <div class="nav-brand">Stores Dashboard</div> 
        
        <button class="logout-btn" onclick="logout()" >Logout</button>
    </nav>
    

    <div class="container">
        <h2 class="page-title">Stores </h2>

        <div class="form-card">

            
            <form method="post" asp-page-handler="Add">
                <input type="hidden" id="storeId" name="Store_Id" />

                <div class="form-row">
                    <div class="form-group">
                        <label>Store Name</label>
                        <input type="text" id="name" name="Name" required />
                    </div>

                    <div class="form-group">
                        <label>Club ID</label>
                        <input type="number" id="clubId" name="Club_Id" required />
                    </div>
                </div>

                <div class="button-row">
                    <button type="submit" class="btn add">➕ Add</button>
                    <button type="submit" class="btn edit" formaction="?handler=Update">✏ Edit</button>
                    <button type="button" class="btn clear" onclick="clearForm()">🧹 Clear</button>
                    <button type="button" class="btn exit" onclick="exitDashboard()">🚪 Exit</button>
                </div>
            </form>

            
            <div class="button-row">
                <form method="post" asp-page-handler="Delete">
                    <input type="hidden" name="Store_Id" id="deleteStoreId" />
                    <button type="submit" class="btn delete">🗑 Delete</button>
                </form>
            </div>

        </div>

        <div class="table-card">
            <h3>📋 Stores List</h3>
            <table id="storesTable">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Name</th>
                        <th>Club ID</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (System.Data.DataRow row in Model.StoresTable.Rows)
                    {
                        <tr onclick="selectStore(this)"
                            data-id="@row["Store_Id"]"
                            data-name="@row["Name"]"
                            data-club="@row["Club_Id"]">

                            <td>@row["Store_Id"]</td>
                            <td>@row["Name"]</td>
                            <td>@row["Club_Id"]</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <script src="~/js/stores.js"></script>
</body>
</html>