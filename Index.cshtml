@page
@model gymmm.Pages.IndexModel
<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Login — Gym System</title>
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <link rel="stylesheet" href="style.css">

    <style>
        body {
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            background: #f6f7fb;
        }

        .login-card {
            width: 360px;
            border-radius: 12px;
            padding: 22px;
            box-shadow: 0 6px 30px rgba(20,20,50,0.08);
            background: #fff;
        }

            .login-card h2 {
                margin: 0 0 12px;
                font-size: 20px;
                color:#1F2937
            }

        .login-row {
            margin-bottom: 12px;
        }

            .login-row label {
                display: block;
                font-size: 13px;
                margin-bottom: 6px;
            }

            .login-row input {
                width: 100%;
                padding: 10px 12px;
                border-radius: 8px;
                border: 1px solid #ddd;
            }

        .btn-primary {
            width: 100%;
            padding: 10px 12px;
            border-radius: 8px;
            border: none;
            font-weight: 600;
            cursor: pointer;
        }

        .error {
            color: #a33;
            font-size: 13px;
            margin-top: 8px;
        }
    </style>
</head>
<body>

    <div class="login-card">
        <h2>Gym System — Login</h2>

        <form method="post">
            <div class="login-row">
                <label>Email</label>
                <input type="email" name="Email" required />
            </div>

            <div class="login-row">
                <label>Password</label>
                <input type="password" name="Password" required />
            </div>

            <button type="submit" class="btn-primary">Sign in</button>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="error">@Model.ErrorMessage</div>
            }
        </form>
    </div>

</body>
</html>