@page
@model gymmm.Pages.ProductsModel
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Products</title>
    <link rel="stylesheet" href="style.css" />
</head>
<body>

    <nav class="navbar">
        <div class="nav-brand">Screen Dashboard</div>
        <button class="logout-btn" onclick="logout()">Logout</button>
    </nav>

    <div class="container">
        <h2 class="page-title">Products</h2>

        <div class="form-card">

            
            <form id="productForm" method="post" asp-page-handler="Add">
                <input type="hidden" id="productId" name="ProductId" />

                <div class="form-row">
                    <div class="form-group">
                        <label>Name</label>
                        <input type="text" id="name" name="Name" required />
                    </div>

                    <div class="form-group">
                        <label>Price</label>
                        <input type="number" step="0.01" id="price" name="Price" required />
                    </div>

                    <div class="form-group">
                        <label>Currency ID</label>
                        <input type="number" id="currencyId" name="CurrencyId" required />
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group" style="width:100%">
                        <label>Description</label>
                        <textarea id="description" name="Description" rows="3"></textarea>
                    </div>
                </div>

                <div class="button-row">
                    <button type="submit" class="btn add">➕ Add</button>
                    <button type="submit" class="btn edit" formaction="?handler=Update">✏ Edit</button>
                    <button type="button" class="btn clear" onclick="clearForm()">🧹 Clear</button>
                    <button type="button" class="btn exit" onclick="exitDashboard()">🚪 Exit</button>
                </div>
            </form>

            
            <div class="button-row">
                <form method="post" asp-page-handler="Delete">
                    <input type="hidden" id="deleteProductId" name="ProductId" />
                    <button type="submit" class="btn delete">🗑 Delete</button>
                </form>
            </div>

        </div>

        <div class="table-card">
            <h3>📋 Products List</h3>
            <table id="productsTable">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Name</th>
                        <th>Description</th>
                        <th>Price</th>
                        <th>Currency</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (System.Data.DataRow row in Model.ProductsTable.Rows)
                    {
                        <tr onclick="selectProduct(this)"
                            data-id="@row["Product_Id"]"
                            data-name="@row["Name"]"
                            data-description="@row["Description"]"
                            data-price="@row["Price"]"
                            data-currency="@row["Currency_Id"]">

                            <td>@row["Product_Id"]</td>
                            <td>@row["Name"]</td>
                            <td>@row["Description"]</td>
                            <td>@row["Price"]</td>
                            <td>@row["Currency_Id"]</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <script src="~/js/products.js"></script>
</body>
</html>