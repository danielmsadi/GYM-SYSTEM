@page
@model gymmm.Pages.UsersModel
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>User Management</title>
    <link rel="stylesheet" href="style.css" />
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700&display=swap" rel="stylesheet">
</head>
<body>
    
    <nav class="navbar">
    <div class="nav-brand">User Dashboard</div>
    <button class="logout-btn" onclick="logout()">Logout</button>
    </nav>

    
    <div class="container">
        <h2 class="page-title">Users</h2>

        <div class="form-card">
            <form id="userForm" method="post" asp-page-handler="AddUser">
                <input type="hidden" id="userId" name="User_Id">
                <div class="form-row">
                    <div class="form-group">
                        <label>Name</label>
                        <input type="text" id="name" name="Name" placeholder="Enter full name" required>
                    </div>

                    <div class="form-group">
                        <label>Email</label>
                        <input type="email" id="email" name="Email" placeholder="Enter email" required>
                    </div>

                    <div class="form-group">
                        <label>Gender</label>
                        <select id="gender" name="Gender" required>
                            <option value="">Select Gender</option>
                            <option>Male</option>
                            <option>Female</option>
                            <option>Other</option>
                        </select>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label>Phone</label>
                        <input type="text" id="phone" name="Phone" placeholder="Enter phone number" required>
                    </div>

                    <div class="form-group">
                        <label>Date</label>
                        <input type="datetime-local" id="date" name="Date" required>
                    </div>

                    <div class="form-group">
                        <label>Password</label>
                        <input type="password" id="password" name="Password" placeholder="Enter password" required>
                    </div>
                </div>

                <div class="button-row">
                    <button type="submit" class="btn add" >➕ Add</button>
                    <button type="submit" class="btn edit" formaction="?handler=UpdateUser">Edit</button>
                    
                    
                    <button type="button" class="btn clear" onclick="clearForm()">🧹 Clear</button>
                    <button type="button" class="btn exit" onclick="exitDashboard()">🚪 Exit</button>
                </div>
            </form>
           
            <div class="button-row">
                <form method="post" asp-page-handler="DeleteUser" style="display:inline;">
                    <input type="hidden" name="User_Id" id="deleteUserId" />

                <button type="submit" class="btn delete">🗑 Delete</button>
                </form>
            </div>

        <div class="table-card">
            <h3>📋 User List</h3>
            <table id="userTable">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Gender</th>
                        <th>Phone</th>
                        <th>Date</th>
                        <th>Password</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (System.Data.DataRow row in Model.UsersTable.Rows)
                    {
                        <tr onclick="selectUser(this)"
                            data-id="@row["User_Id"]"
                            data-name="@row["Name"]"
                            data-email="@row["Email"]"
                            data-gender="@row["Gender"]"
                            data-phone="@row["Phone"]"
                            data-date="@row["Date"]"
                            data-password="@row["Password"]">

                            <td>@row["Name"]</td>
                            <td>@row["Email"]</td>
                            <td>@row["Gender"]</td>
                            <td>@row["Phone"]</td>
                            <td>@row["Date"]</td>
                            <td>@row["Password"]</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <script src="/js/users.js"></script>
</body>
</html>

