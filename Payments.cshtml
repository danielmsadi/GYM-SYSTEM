@page
@model gymmm.Pages.PaymentsModel
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Payments</title>
    <link rel="stylesheet" href="style.css" />
</head>
<body>

    <nav class="navbar">
        <div class="nav-brand">Screen Dashboard</div>
        <button class="logout-btn" onclick="logout()">Logout</button>
    </nav>

    <div class="container">
        <h2 class="page-title">Payments</h2>

        <div class="form-card">

            
            <form id="paymentForm" method="post" asp-page-handler="Add">
                <input type="hidden" id="paymentId" name="PaymentId" />

                <div class="form-row">
                    <div class="form-group">
                        <label>Payment Method ID</label>
                        <input type="number" id="methodId" name="Paymentmethod_Id" required />
                    </div>

                    <div class="form-group">
                        <label>Type</label>
                        <input type="text" id="type" name="Type" required />
                    </div>

                    <div class="form-group">
                        <label>Tax</label>
                        <input type="number" step="0.01" id="tax" name="Tax" required />
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label>Amount</label>
                        <input type="number" step="0.01" id="amount" name="Amount" required />
                    </div>

                    <div class="form-group">
                        <label>Currency ID</label>
                        <input type="number" id="currencyId" name="Currency_Id" required />
                    </div>
                </div>

                <div class="button-row">
                    <button type="submit" class="btn add">➕ Add</button>
                    <button type="submit" class="btn edit" formaction="?handler=Update">✏ Edit</button>
                    <button type="button" class="btn clear" onclick="clearForm()">🧹 Clear</button>
                    <button type="button" class="btn exit" onclick="exitDashboard()">🚪 Exit</button>
                </div>
            </form>

            
            <div class="button-row">
                <form method="post" asp-page-handler="Delete">
                    <input type="hidden" id="deletePaymentId" name="PaymentId" />
                    <button type="submit" class="btn delete">🗑 Delete</button>
                </form>
            </div>

        </div>

        <div class="table-card">
            <h3>📋 Payments List</h3>
            <table id="paymentsTable">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Method</th>
                        <th>Type</th>
                        <th>Tax</th>
                        <th>Amount</th>
                        <th>Currency</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (System.Data.DataRow row in Model.PaymentsTable.Rows)
                    {
                        <tr onclick="selectPayment(this)"
                            data-id="@row["Old_Payment_Id"]"
                            data-method="@row["Paymentmethod_Id"]"
                            data-type="@row["Type"]"
                            data-tax="@row["Tax"]"
                            data-amount="@row["Ammount"]"
                            data-currency="@row["Currency_Id"]">

                            <td>@row["Old_Payment_Id"]</td>
                            <td>@row["Paymentmethod_Id"]</td>
                            <td>@row["Type"]</td>
                            <td>@row["Tax"]</td>
                            <td>@row["Ammount"]</td>
                            <td>@row["Currency_Id"]</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <script src="~/js/payments.js"></script>
</body>
</html>