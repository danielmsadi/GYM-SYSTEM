@page
@model gymmm.Pages.ExpensesModel
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <title>Expenses</title>
    <link rel="stylesheet" href="style.css" />
</head>
<body>

    <nav class="navbar">
        <div class="nav-brand">Expenses Dashboard</div>
        <button class="logout-btn" onclick="logout()">Logout</button>
    </nav>

    <div class="container">
        <h2 class="page-title">Expenses</h2>

        <div class="form-card">
            <form method="post" asp-page-handler="Add" id="expenseForm">
                <input type="hidden" id="expenseId" name="ExpenseId" />

                <div class="form-row">
                    <div class="form-group">
                        <label>Salary ID</label>
                        <input type="number" id="salaryId" name="Salary_Id" required />
                    </div>

                    <div class="form-group">
                        <label>Type</label>
                        <input type="text" id="type" name="Type" required />
                    </div>

                    <div class="form-group">
                        <label>Payment ID</label>
                        <input type="number" id="paymentId" name="Payment_Id" required />
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label>Amount</label>
                        <input type="number" step="0.01" id="amount" name="Amount" required />
                    </div>

                    <div class="form-group">
                        <label>Currency ID</label>
                        <input type="number" id="currencyId" name="CurrencyId" required />
                    </div>

                    <div class="form-group">
                        <label>Date</label>
                        <input type="datetime-local" id="date" name="Date" required />
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group" style="width:100%;">
                        <label>Notes</label>
                        <input type="text" id="notes" name="Notes" />
                    </div>
                </div>

                <div class="button-row">
                    <button type="submit" class="btn add">➕ Add</button>
                    <button type="submit" class="btn edit" formaction="?handler=Update">✏ Edit</button>
                    <button type="button" class="btn clear" onclick="clearForm()">🧹 Clear</button>
                    <button type="button" class="btn exit" onclick="exitDashboard()">🚪 Exit</button>
                </div>
            </form>

            <div class="button-row">
                <form method="post" asp-page-handler="Delete">
                    <input type="hidden" name="ExpenseId" id="deleteExpenseId" />
                    <button type="submit" class="btn delete">🗑 Delete</button>
                </form>
            </div>
        </div>

        <div class="table-card">
            <h3>📋 Expenses List</h3>
            <table id="expensesTable">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Salary</th>
                        <th>Type</th>
                        <th>Payment</th>
                        <th>Amount</th>
                        <th>Currency</th>
                        <th>Date</th>
                        <th>Notes</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (System.Data.DataRow row in Model.ExpensesTable.Rows)
                    {
                        <tr onclick="selectExpense(this)"
                            data-id="@row["Expense_Id"]"
                            data-salary="@row["Salary_Id"]"
                            data-type="@row["Type"]"
                            data-payment="@row["Payment_Id"]"
                            data-amount="@row["Amount"]"
                            data-currency="@row["Currency_Id"]"
                            data-date="@row["Date"]"
                            data-notes="@row["Notes"]">

                            <td>@row["Expense_Id"]</td>
                            <td>@row["Salary_Id"]</td>
                            <td>@row["Type"]</td>
                            <td>@row["Payment_Id"]</td>
                            <td>@row["Amount"]</td>
                            <td>@row["Currency_Id"]</td>
                            <td>@row["Date"]</td>
                            <td>@row["Notes"]</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <script src="~/js/expenses.js"></script>
</body>
</html>